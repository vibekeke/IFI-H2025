# Append numbers 0-9
Az"[0-9]"
# Append numbers 00-99
Az"[0-9][0-9]"
# Append numbers 000-999
Az"[0-9][0-9][0-9]"

# Prepend numbers 0-9
Az"^[0-9]"
# Prepend numbers 00-99
Az"^[0-9][0-9]"

# Common leet substitutions
s/a/@/
s/a/4/
s/e/3/
s/i/1/
s/i/!/
s/o/0/
s/s/$/
s/s/5/
s/t/7/
s/l/1/

# Capitalize first letter
c
# Capitalize all letters
u

# Toggle case (Capital/lower)
t
T

# Duplicate words
d
